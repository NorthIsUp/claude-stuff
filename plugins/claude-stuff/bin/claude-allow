#!/usr/bin/env zsh



if [[ -z $2 ]]; then
    print -u2 "usage: $0 web|search|read|cmd|mcp <pattern>"
    exit 1
fi

case $1 {
    (web)    tool="WebFetch(domain:${2})" ;;
    (search) tool="WebSearch(${2})" ;;
    (read)   tool="Read(${2})" ;;
    (cmd)    tool="Bash(${2}:*)" ;;
    (mcp)    tool="mcp__${2}" ;;
    (*)      print -u2 "first arg must be web|search|read|cmd|mcp"; exit 1 ;;
}

local tmp=$(mktemp)
jq --arg tool "$tool" '.permissions.allow = (.permissions.allow + [$tool] | unique | sort)' ~/.claude/settings.json > $tmp \
  && mv $tmp ~/.claude/settings.json

print "Added: $tool"
